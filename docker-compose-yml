version: "3.9"

services:
  deepshield:

    container_name: bharproj

    build: .

    working_dir: /workspace

    volumes:
      - .:/workspace

    stdin_open: true
    tty: true

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]

    runtime: nvidia